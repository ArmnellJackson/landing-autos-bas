---
/* Sección hero responsive: título principal con tipografía fluida, estadísticas adaptativas
   e imagen destacada. Espaciados reducidos en móvil, escalando progresivamente en desktop. */
---

<section class="relative min-h-[100dvh] flex flex-col justify-center pt-16 sm:pt-20 overflow-hidden bg-background">
  <!-- Decoraciones de fondo con azul eléctrico -->
  <div class="absolute top-0 right-0 w-1/2 h-full bg-primary/5 -skew-x-12 transform origin-top-right z-0"></div>
  <div class="absolute -bottom-24 -left-24 w-64 sm:w-96 h-64 sm:h-96 bg-primary/10 rounded-full blur-3xl z-0"></div>

  <div class="container mx-auto px-4 md:px-6 relative z-10 grid lg:grid-cols-2 gap-8 lg:gap-12 items-center py-6 sm:py-3">
    <!-- Contenido de texto -->
    <div class="flex flex-col gap-4 sm:gap-6 max-w-2xl animate-fade-in">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary/10 text-primary text-xs font-bold uppercase tracking-widest border border-primary/20 self-start">
        <span class="w-2 h-2 rounded-full bg-primary animate-pulse"></span>
        Premium Car Sales
      </div>

      <h1 class="text-4xl sm:text-5xl md:text-7xl lg:text-8xl font-black text-foreground uppercase leading-[0.9] tracking-tighter">
        FIND THE BEST <br />
        <span class="text-primary italic">LUXURY</span> CAR <br />
        FOR YOU
      </h1>

      <p class="text-muted-foreground text-base sm:text-lg md:text-xl max-w-lg leading-relaxed font-medium">
        Discover the world's most prestigious vehicles at unbeatable prices.
        Premium selection, expert guidance, and the best deals in South Florida.
      </p>

      <!-- Estadísticas: tamaños y espaciados escalables -->
      <div class="grid grid-cols-3 gap-4 sm:gap-8 mt-6 pt-6 sm:mt-12 sm:pt-12 border-t border-border/50">
        <div>
          <p class="text-2xl sm:text-3xl font-black text-foreground leading-none">500+</p>
          <p class="text-[10px] sm:text-xs text-muted-foreground uppercase font-bold tracking-widest mt-1 sm:mt-2">Cars Sold</p>
        </div>
        <div>
          <p class="text-2xl sm:text-3xl font-black text-foreground leading-none">12k+</p>
          <p class="text-[10px] sm:text-xs text-muted-foreground uppercase font-bold tracking-widest mt-1 sm:mt-2">Happy Clients</p>
        </div>
        <div>
          <p class="text-2xl sm:text-3xl font-black text-foreground leading-none">24h</p>
          <p class="text-[10px] sm:text-xs text-muted-foreground uppercase font-bold tracking-widest mt-1 sm:mt-2">Expert Support</p>
        </div>
      </div>
    </div>

    <!-- Imagen principal con tamaño adaptativo -->
    <div class="relative group h-full flex items-center justify-center lg:justify-end mt-4 lg:mt-0">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[120%] h-[80%] bg-primary rotate-[-15deg] opacity-10 blur-2xl group-hover:opacity-20 transition-opacity duration-700"></div>

      <img
        src="https://images.unsplash.com/photo-1503376780353-7e6692767b70?auto=format&fit=crop&q=80&w=1200"
        alt="Luxury Car"
        class="relative z-10 w-full max-w-md sm:max-w-xl lg:max-w-3xl drop-shadow-[0_25px_50px_rgba(0,0,0,0.5)] group-hover:scale-105 transition-transform duration-700 ease-out"
      />

    </div>
  </div>

</section>

<style>
  @keyframes fade-in {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in {
    animation: fade-in 1s ease-out forwards;
  }
</style>
