---
import { Shield, Clock, Award, Star } from 'lucide-react';
import { Badge } from '@/components/ui/badge';

const features = [
  {
    title: "Premium Quality",
    desc: "We only offer vehicles that pass our 200+ point inspection.",
    icon: Award
  },
  {
    title: "Secure Payment",
    desc: "100% secure payment methods and flexible financing options.",
    icon: Shield
  },
  {
    title: "24/7 Support",
    desc: "Our expert team is always available to assist you with any needs.",
    icon: Clock
  },
  {
    title: "Best Prices",
    desc: "We guarantee the most competitive rates in the luxury market.",
    icon: Star
  }
];
---

<section id="about-us" class="py-12 sm:py-16 lg:py-24 bg-background overflow-hidden">
  <div class="container mx-auto px-4 md:px-6">
    <div class="grid lg:grid-cols-2 gap-8 sm:gap-12 lg:gap-16 items-center">
      <div class="relative group">
        <!-- Decoration -->
        <div class="absolute -top-10 -left-10 w-40 h-40 bg-primary/20 rounded-full blur-3xl group-hover:bg-primary/30 transition-all"></div>

        <!-- Imagen con altura adaptativa según breakpoint -->
        <div class="relative z-10 rounded-2xl sm:rounded-3xl overflow-hidden shadow-2xl">
          <img
            src="https://images.unsplash.com/photo-1552519507-da3b142c6e3d?auto=format&fit=crop&q=80&w=1000"
            alt="Showroom"
            class="w-full h-[280px] sm:h-[380px] lg:h-[500px] object-cover group-hover:scale-105 transition-transform duration-700"
          />
          <!-- Overlay Card: padding y posición adaptativa -->
          <div class="absolute bottom-4 left-4 right-4 sm:bottom-8 sm:left-8 sm:right-8 bg-background/90 backdrop-blur-md p-4 sm:p-6 rounded-xl sm:rounded-2xl border border-border/50 shadow-xl">
            <p class="text-primary font-black text-2xl sm:text-3xl italic leading-none mb-1">25+</p>
            <p class="text-[10px] sm:text-xs font-bold uppercase tracking-widest text-muted-foreground">Years of Excellence in Miami</p>
          </div>
        </div>
      </div>

      <div class="space-y-6 sm:space-y-8">
        <div class="space-y-3 sm:space-y-4">
          <Badge variant="outline" class="text-primary border-primary/20 uppercase tracking-widest px-4 py-1 font-bold">Why Choose Us</Badge>
          <h2 class="text-3xl sm:text-4xl md:text-5xl font-black text-foreground uppercase tracking-tighter leading-[0.9]">
            WE ARE THE <span class="text-primary italic">LEADING</span> LUXURY <br class="hidden sm:block" />
            DEALER IN THE REGION
          </h2>
          <p class="text-muted-foreground text-base sm:text-lg font-medium leading-relaxed">
            At Autos Bas, we don't just sell cars; we deliver a lifestyle. Our commitment
            to excellence has made us the trusted choice for car enthusiasts worldwide.
          </p>
        </div>

        <!-- Grid de features: 1 columna en móvil, 2 en sm+ -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 sm:gap-6">
          {features.map((item) => (
            <div class="p-4 sm:p-6 rounded-2xl border border-border/50 hover:border-primary/30 hover:bg-primary/5 transition-all group">
              <div class="bg-muted p-3 rounded-xl w-fit mb-3 sm:mb-4 group-hover:bg-primary group-hover:text-white transition-all">
                <item.icon size={24} />
              </div>
              <h3 class="font-black uppercase tracking-tight mb-1.5 sm:mb-2 group-hover:text-primary transition-colors">{item.title}</h3>
              <p class="text-sm text-muted-foreground leading-relaxed font-medium">
                {item.desc}
              </p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
