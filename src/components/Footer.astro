---
import { Mail, MapPin, Phone, MessageSquare as Message, Globe, User } from 'lucide-react';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
---

<footer id="contact" class="bg-[#121212] text-white py-20 border-t border-white/5">
  <div class="container mx-auto px-4 md:px-6">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-16">
      <!-- Logo and Info -->
      <div class="space-y-6">
        <a href="/" class="flex items-center gap-2 group">
          <div class="bg-primary p-1.5 rounded-sm">
            <span class="text-white font-black text-xl leading-none">B</span>
          </div>
          <div class="flex flex-col leading-none">
            <span class="text-white font-bold text-lg uppercase tracking-tighter italic">Autos Bas</span>
            <span class="text-[10px] text-muted-foreground uppercase tracking-widest font-medium">Dealer Miami</span>
          </div>
        </a>
        <p class="text-muted-foreground text-sm font-medium leading-relaxed max-w-xs">
          The world's most prestigious car dealer. Experience the true definition 
          of luxury and performance in Miami.
        </p>
        <div class="flex gap-4">
          {[Globe, Message, User, Mail].map((Icon) => (
            <a href="#" class="bg-white/5 p-3 rounded-full hover:bg-primary transition-all group">
              <Icon size={18} class="text-white" />
            </a>
          ))}
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="text-sm font-black uppercase tracking-widest mb-8 border-l-4 border-primary pl-4 leading-none">Navigation</h4>
        <ul class="space-y-4">
          {['Home', 'Inventory', 'About Us', 'Services', 'Contact'].map((item) => (
            <li>
              <a href="#" class="text-muted-foreground hover:text-white hover:translate-x-2 transition-all flex items-center gap-2 text-sm font-medium group">
                <span class="w-1 h-1 bg-primary rounded-full group-hover:scale-150 transition-transform"></span>
                {item}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact Info -->
      <div>
        <h4 class="text-sm font-black uppercase tracking-widest mb-8 border-l-4 border-primary pl-4 leading-none">Contact Us</h4>
        <ul class="space-y-6">
          <li class="flex gap-4 items-start">
            <div class="bg-white/5 p-3 rounded-xl text-primary">
              <MapPin size={18} />
            </div>
            <div>
              <p class="text-xs uppercase font-bold text-muted-foreground mb-1 tracking-widest">Address</p>
              <p class="text-sm font-medium">123 Luxury Way, Miami, FL 33101</p>
            </div>
          </li>
          <li class="flex gap-4 items-start">
            <div class="bg-white/5 p-3 rounded-xl text-primary">
              <Phone size={18} />
            </div>
            <div>
              <p class="text-xs uppercase font-bold text-muted-foreground mb-1 tracking-widest">Call Us</p>
              <p class="text-sm font-medium">+1 (305) 123-4567</p>
            </div>
          </li>
          <li class="flex gap-4 items-start">
            <div class="bg-white/5 p-3 rounded-xl text-primary">
              <Mail size={18} />
            </div>
            <div>
              <p class="text-xs uppercase font-bold text-muted-foreground mb-1 tracking-widest">Email</p>
              <p class="text-sm font-medium">info@autosbas.com</p>
            </div>
          </li>
        </ul>
      </div>

      <!-- Newsletter -->
      <div class="space-y-6">
        <h4 class="text-sm font-black uppercase tracking-widest mb-8 border-l-4 border-primary pl-4 leading-none text-white">Newsletter</h4>
        <p class="text-muted-foreground text-sm font-medium leading-relaxed">
          Subscribe to get latest news and special offers.
        </p>
        <div class="flex gap-2">
          <Input 
            placeholder="Your email..." 
            class="bg-white/5 border-none rounded-xl h-12 focus:ring-primary/20 placeholder:text-muted-foreground"
          />
          <Button size="icon" class="h-12 w-14 rounded-xl shadow-lg shadow-primary/20 shrink-0">
            <Mail size={20} />
          </Button>
        </div>
      </div>
    </div>

    <div class="pt-8 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-muted-foreground text-xs font-medium">
        &copy; 2026 <span class="text-white font-bold">Autos Bas Dealer Miami</span>. All rights reserved.
      </p>
      <div class="flex gap-8">
        <a href="#" class="text-muted-foreground hover:text-white text-xs font-medium underline-offset-4 hover:underline transition-colors">Privacy Policy</a>
        <a href="#" class="text-muted-foreground hover:text-white text-xs font-medium underline-offset-4 hover:underline transition-colors">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>
