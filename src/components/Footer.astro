---
/* Footer: datos de contacto reales, dirección con enlace a Google Maps, botón WhatsApp, sin blog. */
import { Mail, MapPin, Phone } from 'lucide-react';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
---

<footer id="contact" class="bg-[#050505] text-white py-12 sm:py-16 lg:py-20 border-t border-white/5">
  <div class="container mx-auto px-4 md:px-6">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 sm:gap-10 lg:gap-12 mb-10 sm:mb-16">
      <!-- Logo e información de la empresa -->
      <div class="space-y-6">
        <a href="/" class="flex items-center gap-2 group">
          <div class="bg-primary p-1.5 rounded-sm">
            <span class="text-white font-black text-xl leading-none">B</span>
          </div>
          <div class="flex flex-col leading-none">
            <span class="text-white font-bold text-lg uppercase tracking-tighter italic">Autos Bas</span>
            <span class="text-[10px] text-gray-400 uppercase tracking-widest font-medium">Dealer Miami</span>
          </div>
        </a>
        <p class="text-gray-400 text-sm font-medium leading-relaxed max-w-xs">
          South Florida's trusted luxury car dealer. Find your dream vehicle
          with the best prices and expert guidance.
        </p>
        <!-- Redes sociales -->
        <div class="flex gap-4">
          <a href="#" class="bg-white/5 p-3 rounded-full hover:bg-primary transition-all" aria-label="Facebook">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
          </a>
          <a href="#" class="bg-white/5 p-3 rounded-full hover:bg-primary transition-all" aria-label="Instagram">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
          </a>
          <a href="mailto:info@autosbas.com" class="bg-white/5 p-3 rounded-full hover:bg-primary transition-all" aria-label="Email">
            <Mail size={18} />
          </a>
          <!-- Icono WhatsApp en redes sociales del footer -->
          <a
            href="https://wa.me/51929438206?text=Hello!%20I'm%20visiting%20your%20website%20Autos%20Bas%20Dealer%20Miami%20and%20I'd%20like%20to%20get%20more%20information%20about%20your%20vehicles.%20Thank%20you!"
            target="_blank"
            rel="noopener noreferrer"
            class="bg-white/5 p-3 rounded-full hover:bg-primary transition-all"
            aria-label="WhatsApp"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          </a>
        </div>
      </div>

      <!-- Enlaces rápidos (sin Blog) -->
      <div>
        <h4 class="text-sm font-black uppercase tracking-widest mb-8 border-l-4 border-primary pl-4 leading-none">Navigation</h4>
        <ul class="space-y-4">
          {['Home', 'Inventory', 'About Us', 'Contact'].map((item) => (
            <li>
              <a href={`#${item.toLowerCase().replace(' ', '-')}`} class="text-gray-400 hover:text-white hover:translate-x-2 transition-all flex items-center gap-2 text-sm font-medium group">
                <span class="w-1 h-1 bg-primary rounded-full group-hover:scale-150 transition-transform"></span>
                {item}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Información de contacto real -->
      <div>
        <h4 class="text-sm font-black uppercase tracking-widest mb-8 border-l-4 border-primary pl-4 leading-none">Contact Us</h4>
        <ul class="space-y-6">
          <!-- Dirección real cliqueable hacia Google Maps -->
          <li class="flex gap-4 items-start">
            <div class="bg-white/5 p-3 rounded-xl text-primary shrink-0">
              <MapPin size={18} />
            </div>
            <div>
              <p class="text-xs uppercase font-bold text-gray-500 mb-1 tracking-widest">Address</p>
              <a
                href="https://www.google.com/maps/search/?api=1&query=5767+Rodman+St+Hollywood+FL+33023"
                target="_blank"
                rel="noopener noreferrer"
                class="text-sm font-medium hover:text-primary transition-colors underline-offset-2 hover:underline"
              >
                5767 Rodman St, Hollywood, FL 33023
              </a>
            </div>
          </li>
          <!-- Botón de llamada/WhatsApp -->
          <li class="flex gap-4 items-start">
            <div class="bg-white/5 p-3 rounded-xl text-primary shrink-0">
              <Phone size={18} />
            </div>
            <div>
              <p class="text-xs uppercase font-bold text-gray-500 mb-1 tracking-widest">WhatsApp / Call Us</p>
              <a
                href="https://wa.me/51929438206?text=Hello!%20I'm%20visiting%20your%20website%20Autos%20Bas%20Dealer%20Miami%20and%20I'd%20like%20to%20get%20more%20information%20about%20your%20vehicles.%20Thank%20you!"
                target="_blank"
                rel="noopener noreferrer"
                class="text-sm font-medium hover:text-primary transition-colors"
              >
                +51 929 438 206
              </a>
            </div>
          </li>
          <li class="flex gap-4 items-start">
            <div class="bg-white/5 p-3 rounded-xl text-primary shrink-0">
              <Mail size={18} />
            </div>
            <div>
              <p class="text-xs uppercase font-bold text-gray-500 mb-1 tracking-widest">Email</p>
              <a href="mailto:info@autosbas.com" class="text-sm font-medium hover:text-primary transition-colors">info@autosbas.com</a>
            </div>
          </li>
        </ul>
      </div>

      <!-- Newsletter -->
      <div class="space-y-4 sm:space-y-6">
        <h4 class="text-sm font-black uppercase tracking-widest mb-4 sm:mb-8 border-l-4 border-primary pl-4 leading-none text-white">Newsletter</h4>
        <p class="text-gray-400 text-sm font-medium leading-relaxed">
          Subscribe to get latest news and special offers.
        </p>
        <div class="flex gap-2">
          <Input
            placeholder="Your email..."
            class="bg-white/5 border-none rounded-xl h-12 focus:ring-primary/20 placeholder:text-gray-500"
          />
          <Button size="icon" class="h-12 w-14 rounded-xl shadow-lg shadow-primary/20 shrink-0">
            <Mail size={20} />
          </Button>
        </div>
      </div>
    </div>

    <div class="pt-6 sm:pt-8 border-t border-white/5 flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-gray-500 text-xs font-medium text-center sm:text-left">
        &copy; 2026 <span class="text-white font-bold">Autos Bas Dealer Miami</span>. All rights reserved.
      </p>
      <div class="flex gap-6 sm:gap-8">
        <a href="#" class="text-gray-500 hover:text-white text-xs font-medium underline-offset-4 hover:underline transition-colors">Privacy Policy</a>
        <a href="#" class="text-gray-500 hover:text-white text-xs font-medium underline-offset-4 hover:underline transition-colors">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>
