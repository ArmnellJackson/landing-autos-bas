---
/* Sección de inventario: consulta la tabla 'inventario' de Supabase con sus imágenes
   y renderiza filtros dinámicos + carrusel de tarjetas con botón de WhatsApp contextual. */
import { Badge } from '@/components/ui/badge';
import { supabase } from '@/lib/supabase';
import InventoryGrid from '@/components/InventoryGrid';

/* Tipado para los registros de inventario con sus imágenes asociadas */
interface InventarioImagen {
  url: string;
  orden: number;
}

interface Vehiculo {
  id: string;
  marca: string;
  modelo: string;
  anio: number;
  precio: number;
  color_exterior: string | null;
  transmision: string | null;
  combustible: string | null;
  millaje: number;
  carroceria: string | null;
  down_payment: number | null;
  inventario_imagenes: InventarioImagen[];
}

/* Consulta a Supabase: trae vehículos disponibles con sus imágenes ordenadas.
   Si el cliente no está disponible (variables de entorno ausentes), devuelve un array vacío. */
let cars: Vehiculo[] = [];

if (supabase) {
  const { data: vehiculos, error } = await supabase
    .from('inventario')
    .select(`
      id, marca, modelo, anio, precio, color_exterior, transmision,
      combustible, millaje, carroceria, down_payment,
      inventario_imagenes ( url, orden )
    `)
    .eq('status', 'disponible')
    .order('created_at', { ascending: false });

  if (error) {
    console.error('Error al consultar inventario:', error.message);
  }

  cars = (vehiculos as Vehiculo[]) ?? [];
}

/* Extrae marcas y años únicos del inventario para los filtros dinámicos */
const marcas = [...new Set(cars.map(c => c.marca.trim()))].sort();
const anios = [...new Set(cars.map(c => c.anio))].sort((a, b) => b - a);
---

<section id="inventory" class="py-24 bg-muted/30">
  <div class="container mx-auto px-4 md:px-6">
    <!-- Encabezado de la sección -->
    <div class="space-y-4 mb-12">
      <Badge variant="outline" class="text-primary border-primary/20 uppercase tracking-widest px-4 py-1 font-bold">Featured Fleet</Badge>
      <h2 class="text-4xl md:text-5xl font-black text-foreground uppercase tracking-tighter leading-none">
        EXPLORE OUR <span class="text-primary italic">EXCLUSIVE</span> INVENTORY
      </h2>
      <p class="text-muted-foreground max-w-xl font-medium">
        Choose from our carefully curated selection of high-performance and luxury vehicles
        available for immediate purchase.
      </p>
    </div>

    <!-- Filtros + carrusel: componente React con estado compartido para filtrado dinámico -->
    <InventoryGrid client:load cars={cars} marcas={marcas} anios={anios} />
  </div>
</section>
