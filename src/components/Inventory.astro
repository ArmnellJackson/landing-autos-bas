---
/* Sección de inventario: muestra las tarjetas de autos con botón WhatsApp individual que envía las características del vehículo. */
import { Users, Fuel, Gauge, ArrowUpRight } from 'lucide-react';
import { Button } from '@/components/ui/button';
import { Badge } from '@/components/ui/badge';
import {
  Card,
  CardContent,
  CardFooter,
  CardHeader,
} from "@/components/ui/card";

/* Datos del inventario: cada auto incluye color y año para el mensaje de WhatsApp */
const cars = [
  {
    name: "Rolls-Royce Ghost",
    price: "$450,000",
    year: 2025,
    color: "Silver",
    image: "https://images.unsplash.com/photo-1631214548473-70d4844401a6?auto=format&fit=crop&q=80&w=800",
    specs: { people: 4, fuel: "Gasoline", trans: "Auto" },
    tag: "Luxury"
  },
  {
    name: "Bentley Continental GT",
    price: "$280,000",
    year: 2025,
    color: "Black",
    image: "https://images.unsplash.com/photo-1621135802920-133df287f89c?auto=format&fit=crop&q=80&w=800",
    specs: { people: 4, fuel: "Gasoline", trans: "Auto" },
    tag: "Exotic"
  },
  {
    name: "Ferrari 812 Superfast",
    price: "$335,000",
    year: 2024,
    color: "Red",
    image: "https://images.unsplash.com/photo-1592198084033-aade902d1aae?auto=format&fit=crop&q=80&w=800",
    specs: { people: 2, fuel: "Hybrid", trans: "Manual" },
    tag: "Sport"
  },
  {
    name: "Porsche 911 Turbo S",
    price: "$210,000",
    year: 2025,
    color: "White",
    image: "https://images.unsplash.com/photo-1503376780353-7e6692767b70?auto=format&fit=crop&q=80&w=800",
    specs: { people: 4, fuel: "Gasoline", trans: "Auto" },
    tag: "Sport"
  },
  {
    name: "Range Rover SV",
    price: "$180,000",
    year: 2024,
    color: "Gray",
    image: "https://images.unsplash.com/photo-1541899481282-d53bffe3c35d?auto=format&fit=crop&q=80&w=800",
    specs: { people: 5, fuel: "Diesel", trans: "Auto" },
    tag: "SUV"
  },
  {
    name: "Lamborghini Urus",
    price: "$230,000",
    year: 2025,
    color: "Yellow",
    image: "https://images.unsplash.com/photo-1580273916550-e323be2ae537?auto=format&fit=crop&q=80&w=800",
    specs: { people: 5, fuel: "Gasoline", trans: "Auto" },
    tag: "SUV"
  }
];

/* Genera la URL de WhatsApp con las características del auto */
function getWhatsAppUrl(car: typeof cars[0]) {
  const msg = encodeURIComponent(
    `Hello! I'm interested in the ${car.year} ${car.name} (${car.color}) listed at ${car.price} on your website. Could you please provide more details about this vehicle? Thank you!`
  );
  return `https://wa.me/51929438206?text=${msg}`;
}
---

<section id="inventory" class="py-24 bg-muted/30">
  <div class="container mx-auto px-4 md:px-6">
    <div class="flex flex-col md:flex-row justify-between items-end gap-6 mb-12">
      <div class="space-y-4">
        <Badge variant="outline" class="text-primary border-primary/20 uppercase tracking-widest px-4 py-1 font-bold">Featured Fleet</Badge>
        <h2 class="text-4xl md:text-5xl font-black text-foreground uppercase tracking-tighter leading-none">
          EXPLORE OUR <span class="text-primary italic">EXCLUSIVE</span> INVENTORY
        </h2>
        <p class="text-muted-foreground max-w-xl font-medium">
          Choose from our carefully curated selection of high-performance and luxury vehicles
          available for immediate purchase.
        </p>
      </div>
      <Button variant="outline" className="rounded-full px-8 font-bold border-2 h-12 hover:bg-primary hover:text-white transition-all group">
        View All Cars
        <ArrowUpRight size={18} class="ml-2 group-hover:rotate-45 transition-transform" />
      </Button>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {cars.map((car) => (
        <Card class="group overflow-hidden border-none shadow-xl hover:shadow-2xl transition-all duration-500 bg-background rounded-3xl">
          <CardHeader class="p-0 relative h-64 overflow-hidden">
            <div class="absolute top-4 left-4 z-20">
              <Badge class="bg-primary/90 hover:bg-primary text-white font-bold px-3 py-1 rounded-lg backdrop-blur-sm">
                {car.tag}
              </Badge>
            </div>
            <img
              src={car.image}
              alt={car.name}
              class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          </CardHeader>
          <CardContent class="p-6">
            <div class="flex justify-between items-start mb-1">
              <h3 class="text-xl font-black uppercase tracking-tight group-hover:text-primary transition-colors">{car.name}</h3>
              <span class="text-xl font-black text-primary italic">{car.price}</span>
            </div>
            <p class="text-xs text-muted-foreground font-medium mb-4">{car.year} · {car.color}</p>

            <div class="grid grid-cols-3 gap-4 py-4 border-y border-border/50">
              <div class="flex flex-col items-center gap-1">
                <Users size={18} class="text-muted-foreground" />
                <span class="text-[10px] font-bold uppercase text-muted-foreground">{car.specs.people} Seats</span>
              </div>
              <div class="flex flex-col items-center gap-1 border-x border-border/50">
                <Gauge size={18} class="text-muted-foreground" />
                <span class="text-[10px] font-bold uppercase text-muted-foreground">{car.specs.trans}</span>
              </div>
              <div class="flex flex-col items-center gap-1">
                <Fuel size={18} class="text-muted-foreground" />
                <span class="text-[10px] font-bold uppercase text-muted-foreground">{car.specs.fuel}</span>
              </div>
            </div>
          </CardContent>
          <CardFooter class="p-6 pt-0 flex gap-3">
            <!-- Botón WhatsApp: envía mensaje con las características específicas del auto -->
            <a
              href={getWhatsAppUrl(car)}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center gap-2 w-full rounded-xl font-bold uppercase tracking-widest h-12 shadow-lg shadow-primary/10 bg-primary text-primary-foreground text-sm hover:opacity-90 transition-opacity"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              Buy Now
            </a>
            <Button variant="outline" className="w-full rounded-xl font-bold uppercase tracking-widest h-12 border-2">Details</Button>
          </CardFooter>
        </Card>
      ))}
    </div>
  </div>
</section>
