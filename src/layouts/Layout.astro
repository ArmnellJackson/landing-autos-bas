---
/* Layout principal: estructura HTML, meta tags, script de tema claro/oscuro y widget de Google Translate. */
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "Autos Bas Dealer Miami - Premium luxury car sales in South Florida" } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>

		<!-- Script de inicialización de tema: evita parpadeo leyendo preferencia antes del render -->
		<script is:inline>
			(function() {
				const stored = localStorage.getItem('theme');
				if (stored === 'dark') {
					document.documentElement.classList.add('dark');
				} else {
					document.documentElement.classList.remove('dark');
				}
			})();
		</script>

		<!-- Google Translate Element: carga el widget y renombra opciones a abreviaturas nativas -->
		<script is:inline>
			/* Mapa de códigos de idioma a abreviaturas cortas en su idioma nativo */
			var gtLangMap = {
				'en':'En','es':'Es','fr':'Fr','de':'De','it':'It','pt':'Pt',
				'nl':'Nl','pl':'Pl','ro':'Ro','sv':'Sv','da':'Da','no':'No',
				'fi':'Fi','el':'El','hu':'Hu','cs':'Cs','bg':'Bg','hr':'Hr',
				'sk':'Sk','sl':'Sl'
			};
			var gtLangNames = {
				'en':'English','es':'Español','fr':'Français','de':'Deutsch',
				'it':'Italiano','pt':'Português','nl':'Nederlands','pl':'Polski',
				'ro':'Română','sv':'Svenska','da':'Dansk','no':'Norsk',
				'fi':'Suomi','el':'Ελληνικά','hu':'Magyar','cs':'Čeština',
				'bg':'Български','hr':'Hrvatski','sk':'Slovenčina','sl':'Slovenščina'
			};

			/* Renombra las opciones del select de Google Translate a abreviaturas nativas */
			function renombrarOpciones() {
				var combo = document.querySelector('.goog-te-combo');
				if (!combo) return false;
				var opts = combo.options;
				for (var i = 0; i < opts.length; i++) {
					var val = opts[i].value;
					if (val && gtLangNames[val]) {
						opts[i].text = gtLangNames[val];
					} else if (val === '') {
						opts[i].text = 'Language';
					}
				}
				return true;
			}

			function googleTranslateElementInit() {
				new google.translate.TranslateElement({
					pageLanguage: 'en',
					includedLanguages: 'en,es,fr,de,it,pt,nl,pl,ro,sv,da,no,fi,el,hu,cs,bg,hr,sk,sl',
					layout: google.translate.TranslateElement.InlineLayout.HORIZONTAL,
					autoDisplay: false
				}, 'google_translate_element');

				/* Espera a que el select se renderice y renombra las opciones */
				var intentos = 0;
				var intervalo = setInterval(function() {
					if (renombrarOpciones() || intentos > 20) clearInterval(intervalo);
					intentos++;
				}, 200);
			}
		</script>
		<script is:inline src="https://translate.google.com/translate_a/element.js?cb=googleTranslateElementInit"></script>
	</head>
	<body class="bg-background text-foreground antialiased overflow-x-hidden">
		<slot />
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
	/* Oculta la barra superior del widget de Google Translate y el iframe de notificación */
	:global(.goog-te-banner-frame),
	:global(#goog-gt-tt),
	:global(.goog-te-balloon-frame),
	:global(.goog-tooltip),
	:global(.goog-tooltip:hover) {
		display: none !important;
	}
	:global(body) {
		top: 0 !important;
		position: static !important;
	}
	/* Oculta el texto "Powered by Google Traductor" y enlaces extra del widget */
	:global(.goog-te-gadget) {
		font-size: 0 !important;
		color: transparent !important;
	}
	:global(.goog-te-gadget span),
	:global(.goog-te-gadget a) {
		display: none !important;
	}
	/* Estilos del selector de idioma con color explícito para ambos temas */
	:global(.goog-te-combo) {
		display: inline-block !important;
		font-size: 12px !important;
		padding: 4px 8px;
		border-radius: 8px;
		border: 1px solid oklch(0.90 0 0);
		background: transparent;
		color: oklch(0.145 0 0) !important;
		font-family: 'Geist Variable', sans-serif;
		font-weight: 600;
		cursor: pointer;
	}
	:global(.dark .goog-te-combo) {
		border-color: oklch(1 0 0 / 12%);
		color: oklch(0.95 0 0) !important;
		background-color: oklch(0.15 0 0) !important;
	}
	/* Opciones del dropdown visibles en dark mode con fondo oscuro y texto claro */
	:global(.dark .goog-te-combo option) {
		background-color: oklch(0.15 0 0) !important;
		color: oklch(0.95 0 0) !important;
	}
	/* Oculta la barra de traducción que aparece al traducir la página */
	:global(.skiptranslate) {
		display: none !important;
	}
	:global(#google_translate_element .skiptranslate) {
		display: block !important;
	}
</style>
