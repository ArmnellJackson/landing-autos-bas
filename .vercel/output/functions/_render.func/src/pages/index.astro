---
/* Página principal tipo catálogo: header fijo, inventario como contenido principal y footer.
   Estructura simplificada enfocada en la exhibición del inventario de vehículos. */
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Inventory from '../components/Inventory.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Autos Bas Dealer Miami | Luxury & Premium Car Sales">
	<div class="min-h-screen flex flex-col">
		<Navbar />
		<main class="flex-1">
			<Inventory />
		</main>
		<Footer />
	</div>
</Layout>
